generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Subscriber {
  id String @id

  email String @unique

  full_name String?

  source String?

  is_waitlist Boolean @default(false)

  is_newsletter Boolean @default(false)

  waitlist_joined_at DateTime?

  newsletter_joined_at DateTime?

  subscribed_at DateTime @default(now())

  ip_address String?

  country String?

  city String?

  region String?

  timezone String?

  user_agent String?

  browser String?

  os String?

  device_type String?

  referrer_url String?

  utm_source String?

  utm_medium String?

  utm_campaign String?

  utm_term String?

  utm_content String?

  consent_given Boolean

  notes String?

  email_jobs EmailJob[]

  email_events EmailEvent[]

  created_at DateTime @default(now())

  updated_at DateTime @updatedAt

  @@map("subscribers")
}

model EmailJob {
  id String @id

  subscriber_id String

  email String

  provider String?

  job_type String

  email_type String?

  status String @default("pending")

  priority Int @default(0)

  scheduled_for DateTime

  attempts Int @default(0)

  max_attempts Int @default(3)

  last_error String?

  locked_at DateTime?

  locked_by String?

  processed_at DateTime?

  email_events EmailEvent[]

  created_at DateTime @default(now())

  updated_at DateTime @updatedAt

  subscriber Subscriber @relation(fields: [subscriber_id], references: [id])

  @@index([status])

  @@index([scheduled_for])

  @@index([subscriber_id])

  @@index([status, scheduled_for])

  @@map("email_jobs")
}

model EmailEvent {
  id String @id

  subscriber_id String

  email_job_id String?

  email String

  email_type String

  provider String

  provider_message_id String?

  status String @default("queued")

  error_message String?

  attempts Int @default(0)

  sent_at DateTime?

  created_at DateTime @default(now())

  subscriber Subscriber @relation(fields: [subscriber_id], references: [id])

  email_job EmailJob? @relation(fields: [email_job_id], references: [id])

  @@index([subscriber_id])

  @@index([email_type])

  @@index([status])

  @@index([subscriber_id, email_type])

  @@map("email_events")
}